<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vn_ward_list" model="ir.ui.view">
        <field name="name">frm.vn.ward.list</field>
        <field name="model">frm.vn.ward</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code" optional="show"/>
                <field name="state_id"/>
            </list>
        </field>
    </record>

    <record id="view_vn_ward_form" model="ir.ui.view">
        <field name="name">frm.vn.ward.form</field>
        <field name="model">frm.vn.ward</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="state_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vn_ward_search" model="ir.ui.view">
        <field name="name">frm.vn.ward.search</field>
        <field name="model">frm.vn.ward</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="state_id"/>
                <filter name="group_state" string="Tỉnh / Thành phố" context="{'group_by': 'state_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_vn_ward" model="ir.actions.act_window">
        <field name="name">Phường / Xã</field>
        <field name="res_model">frm.vn.ward</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_vn_state" model="ir.actions.act_window">
        <field name="name">Tỉnh / Thành phố</field>
        <field name="res_model">res.country.state</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('country_id.code', '=', 'VN')]</field>
    </record>

    <menuitem id="menu_vn_address_root" name="Địa giới VN" sequence="95" groups="base.group_system"/>
    <menuitem id="menu_vn_state" name="Tỉnh / Thành phố" parent="menu_vn_address_root" action="action_vn_state" sequence="10"/>
    <menuitem id="menu_vn_ward" name="Phường / Xã" parent="menu_vn_address_root" action="action_vn_ward" sequence="20"/>

</odoo>
